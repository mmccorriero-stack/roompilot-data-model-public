DROP TABLE IF EXISTS fact_room_nights;

CREATE TABLE fact_room_nights AS
WITH RECURSIVE room_nights AS (
    SELECT
        reservation_id,
        hotel_id,
        booking_date,
        booking_date_key,
        checkin_date,
        checkout_date,
        reservation_status,
        channel,
        segment,
        rate_plan_code,
        guest_count,
        rooms_booked,
        room_revenue,
        total_revenue,
        is_cancelled,
        checkin_date AS stay_date
    FROM fact_reservations
    WHERE checkin_date IS NOT NULL
      AND checkout_date IS NOT NULL
      AND julianday(checkout_date) > julianday(checkin_date)

    UNION ALL

    SELECT
        reservation_id,
        hotel_id,
        booking_date,
        booking_date_key,
        checkin_date,
        checkout_date,
        reservation_status,
        channel,
        segment,
        rate_plan_code,
        guest_count,
        rooms_booked,
        room_revenue,
        total_revenue,
        is_cancelled,
        date(stay_date, '+1 day') AS stay_date
    FROM room_nights
    WHERE date(stay_date, '+1 day') < checkout_date
)
SELECT
    reservation_id,
    hotel_id,

    booking_date,
    booking_date_key,

    checkin_date,
    checkout_date,

    stay_date,
    CAST(strftime('%Y%m%d', stay_date) AS INTEGER) AS stay_date_key,

    reservation_status,
    channel,
    segment,
    rate_plan_code,

    guest_count,
    rooms_booked,

    room_revenue,
    total_revenue,

    CASE
        WHEN room_revenue IS NOT NULL
             AND (julianday(checkout_date) - julianday(checkin_date)) > 0
            THEN ROUND(
                room_revenue / (julianday(checkout_date) - julianday(checkin_date)),
                2
            )
        ELSE NULL
    END AS night_revenue,

    CASE
        WHEN stay_date = checkin_date THEN 1
        ELSE 0
    END AS is_arrival_night,

    CASE
        WHEN date(stay_date, '+1 day') = checkout_date THEN 1
        ELSE 0
    END AS is_last_night,

    is_cancelled

FROM room_nights;
